# DTL GenAI framework — deployment configuration.
#
# Copy this file to ".env" and adjust as needed:
#     cp .env.example .env
#
# .env is sourced by IRIS/run.sh (and scripts/demo.sh). It is git-ignored so your
# local ports/secrets are not committed.

# ---- Host port mappings -----------------------------------------------------
# IRIS always listens on 1972 (superserver) and 52773 (web/management) INSIDE the
# container. These settings control which HOST ports those are published to, so you
# can avoid clashes with other services on the machine (or expose different ports on
# a shared server). The UI/health URLs printed by run.sh use IRIS_WEB_PORT.
#
#   <HOST_PORT>:<container 52773>   ->  IRIS_WEB_PORT
#   <HOST_PORT>:<container 1972>    ->  IRIS_SUPERSERVER_PORT
IRIS_WEB_PORT=52773
IRIS_SUPERSERVER_PORT=1972

# ---- Container / image ------------------------------------------------------
# Container name (also overridable as the first arg to run.sh) and the IRIS image.
IRIS_CONTAINER=iris-dtl
IRIS_IMAGE=intersystemsdc/irishealth-community:latest

# IRIS instance password (set on first container create).
IRIS_PASSWORD=SYS

# ---- Mock LLM ---------------------------------------------------------------
# Host port for the bundled offline mock LLM (only used for the offline demo; real
# providers are configured per-request in the UI Settings tab).
MOCK_LLM_PORT=8085
