# Keep shell scripts and ObjectScript/HL7 sources LF-only so they work inside the
# Linux IRIS container even when checked out on Windows. (CRLF in a .sh corrupts
# paths passed into IRIS — e.g. #5007 invalid directory.)
*.sh    text eol=lf
*.cls   text eol=lf
*.mac   text eol=lf
*.hl7   text eol=lf
*.xml   text eol=lf
*.py    text eol=lf
